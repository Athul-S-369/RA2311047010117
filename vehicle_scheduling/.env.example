# Paste the full Authorization header value from Pre-Test Setup (e.g. Bearer <token>)
EVALUATION_AUTH_HEADER=

# Optional overrides (full URLs; default base is http://20.207.122.201/evaluation-service)
# DEPOTS_URL=http://20.207.122.201/evaluation-service/depots
